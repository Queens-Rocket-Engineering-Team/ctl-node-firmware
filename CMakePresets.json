{
    "version": 8,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "no-preset",
            "displayName": "No preset selected",
            "description": "Fallback preset if no preset is selected. Will abort.",
            "generator": "Ninja",
            "binaryDir": "build"
        },
        {
            "name": "panda-v3",
            "displayName": "PANDA v3",
            "generator": "Ninja",
            "binaryDir": "build",
            "cacheVariables": {
                "BOARD_CONFIG": "${sourceDir}/boards/panda_v3/esp_config.json",
                "BOARD_MAPPING": "${sourceDir}/boards/panda_v3/esp_mapping.json"
            }
        },
        {
            "name": "gse-node",
            "displayName": "GSE Control Node",
            "generator": "Ninja",
            "binaryDir": "build",
            "cacheVariables": {
                "BOARD_CONFIG": "${sourceDir}/boards/gse_node/esp_config.json",
                "BOARD_MAPPING": "${sourceDir}/boards/gse_node/esp_mapping.json"
            }
        }
    ]
}